rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User document ───────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // ── Accounts ─────────────────────────────────────────────────────────
      match /accounts/{accountId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Transactions ─────────────────────────────────────────────────────
      match /transactions/{txId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Recurring Transactions ───────────────────────────────────────────
      match /recurring_transactions/{rtId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Savings Goals ────────────────────────────────────────────────────
      match /goals/{goalId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Badges (gamification) — escritura solo por Cloud Functions ────────
      match /badges/{badgeId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // ── FCM Tokens ───────────────────────────────────────────────────────
      match /fcm_tokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Households ──────────────────────────────────────────────────────────
    match /households/{householdId} {

      // Función auxiliar: ¿es el usuario miembro de este hogar?
      function isMember() {
        return request.auth != null &&
               request.auth.uid in resource.data.memberUids;
      }

      // Cualquier usuario autenticado puede leer (necesario para buscar por inviteCode)
      allow read: if request.auth != null;

      // Solo usuarios autenticados pueden crear un hogar
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.memberUids;

      // Solo miembros actuales pueden actualizar (unirse, salir, cambiar nombre)
      allow update: if isMember();

      // Nadie puede borrar hogares desde el cliente
      allow delete: if false;

      // ── Transacciones compartidas del hogar ──────────────────────────────
      match /transactions/{txId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberUids;
      }
    }
  }
}
